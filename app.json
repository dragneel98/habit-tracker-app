{
  "expo": {
    "name": "Gestor dee Hábitos",
    "slug": "habit-tracker-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habittracker.app"
    },
    "android": {
      "package": "com.habittracker.app",
      "adaptiveIcon": {
        "backgroundColor": "#F7F7FC"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#6C5CE7"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-status-bar"
    ]
  }
}